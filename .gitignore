.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- 日誌檔案 (Logs) ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


