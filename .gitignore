# --- 依賴管理 (Dependencies) ---
node_modules/
.pnpm-debug.log*

# --- 編譯產物 (Build Artifacts) ---
dist/
build/
*.tsbuildinfo
.next/
.vite/
out/

# --- 環境變數 (Secrets/Environment) ---
