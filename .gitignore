.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# --- Turborepo 快取 (Monorepo specific) ---
.turbo/

# --- 測試與覆蓋率 (Testing) ---
coverage/
.nyc_output/



# --- 作業系統產生的暫存檔 (OS generated) ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

